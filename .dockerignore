# Node dependencies (installed inside container)
node_modules

# Next.js build output (rebuilt inside container)
.next

# Local environment files (never copy secrets)
.env
.env.local
.env.development
.env.production

# Logs
npm-debug.log
yarn-error.log
pnpm-debug.log

# Git files (not needed inside image)
.git
.gitignore

# OS / editor files
.DS_Store
Thumbs.db

# Prisma local artifacts (safe to regenerate)
prisma/dev.db
