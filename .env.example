// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
} 

# ===============================
# Application
# ===============================
NODE_ENV=development
PORT=3000

# ===============================
# Database (PostgreSQL)
# ===============================
POSTGRES_DB=brightpath_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Prisma database connection
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/brightpath_db

# ===============================
# Docker / Compose
# ===============================
COMPOSE_PROJECT_NAME=bright-path

# ===============================
# Prisma
# ===============================
PRISMA_CLIENT_ENGINE_TYPE=binary

# ===============================
# Optional / Testing
# ===============================
DATABASE_URL_TEST=postgresql://postgres:your_password_here@localhost:5432/brightpath_test