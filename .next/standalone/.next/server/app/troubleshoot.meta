{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/troubleshoot/layout,_N_T_/troubleshoot/page,_N_T_/troubleshoot"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/troubleshoot/__PAGE__",
    "/troubleshoot",
    "/_index",
    "/_head"
  ]
}